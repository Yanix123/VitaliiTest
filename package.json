{
  "name": "movies-catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "db:generate": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first drizzle-kit generate",
    "db:migrate": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first drizzle-kit migrate",
    "db:push": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first drizzle-kit push",
    "db:seed": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first tsx scripts/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.11",
    "better-auth": "^1.4.5",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "postgres": "^3.4.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.67.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
