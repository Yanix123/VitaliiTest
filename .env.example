# Supabase Postgres — pooled connection (transaction pooler, port 6543), used at runtime
DATABASE_URL=
# Supabase Postgres — direct/session connection (port 5432), used for migrations + seed
DIRECT_URL=
# Better Auth secret — at least 32 characters (e.g. `openssl rand -base64 32`)
BETTER_AUTH_SECRET=
# Better Auth base URL — your app origin (e.g. http://localhost:3000)
BETTER_AUTH_URL=http://localhost:3000

# Public app URL for the browser auth client (optional; defaults to current origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_API_KEY=